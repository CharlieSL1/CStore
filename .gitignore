# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env
*.egg-info/
.eggs/
dist/
build/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Model checkpoints (too large for git; use Hugging Face or separate release)
model/checkpoints/
*.safetensors
*.bin
*.pt
*.pth

# Generated outputs (eval runs)
model/Generated/

# Webapp generated files (stored locally, not in repo).
# The old Flask-only `webapp/` was renamed to `webapp-next/`; `webapp-next/.gitignore`
# already covers its build artefacts and rendered runs, but we keep both paths
# here so a future clone of `webapp/` would still be protected.
webapp/generated/*
!webapp/generated/.gitkeep
webapp-next/generated/
webapp-next/.next/
webapp-next/node_modules/

# Dataset (user-provided)
Dataset/
*.zip

# Logs
*.log
wandb/
